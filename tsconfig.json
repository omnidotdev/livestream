{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "build",
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "build",
    "resolveJsonModule": true,
    "types": ["@types/bun", "@types/react"]
  },
  "include": ["src/**/*"],
  "exclude": ["build", "node_modules"]
}
